PORT=3000
LOG_LEVEL=info
MONGODB_URI=mongodb://mongo:27017/lifi?replicaSet=rs0
WORKER_CHAIN_KEY=polygon
WORKER_MODULE=fee-events
WORKER_EVENT=fees-collected
WORKER_POLL_INTERVAL_MS=10000
WORKER_LEASE_DURATION_MS=30000
WORKER_LEASE_RENEW_INTERVAL_MS=5000
# Conservative defaults for free-tier RPC providers.
WORKER_INITIAL_BATCH_SIZE=1000
WORKER_MIN_BATCH_SIZE=100
WORKER_MAX_BATCH_SIZE=5000
WORKER_CONFIRMATIONS_FALLBACK=64
WORKER_REORG_LOOKBACK=32
WORKER_STARTUP_TIMEOUT_MS=10000
CHAIN_KEYS=polygon
# Copy this file to .env and replace the RPC URL with your own archive-capable endpoint if available.
# Example for Alchemy Free:
# CHAIN_POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
CHAIN_POLYGON_RPC_URLS=https://polygon.drpc.org,https://polygon-bor-rpc.publicnode.com
CHAIN_POLYGON_START_BLOCK=78600000
CHAIN_POLYGON_FEE_COLLECTOR_ADDRESS=0xbD6C7B0d2f68c2b7805d88388319cfB6EcB50eA9
